body { margin:0; font-family:'Arial',sans-serif; background:#e0f7fa; }
.screen { display:none; }
.screen.active { display:block; }

.login-wrap, .content-card { max-width:500px; margin:20px auto; background:#fff; padding:20px; border-radius:12px; box-shadow:0 4px 10px rgba(0,0,0,0.1); }

h1,h2,h3,h4{ margin:0 0 10px; }
input, select, button { width:100%; padding:10px; margin:5px 0; border-radius:6px; border:1px solid #ccc; }
button{ background:#00796b; color:#fff; font-weight:bold; cursor:pointer; }
button:hover{ background:#004d40; }

.balance-card{ background:#b2dfdb; padding:15px; margin:20px 0; border-radius:12px; }
.balance-main h1{ font-size:28px; }
.calc-box{ background:#e0f2f1; padding:10px; border-radius:6px; margin:10px 0; }

.bottom-nav{ display:flex; justify-content:space-around; position:fixed; bottom:0; width:100%; background:#00796b; padding:10px 0; }
.bottom-nav .nav-btn{ background:none; border:none; color:#fff; font-weight:bold; cursor:pointer; }
.bottom-nav .nav-btn.active{ text-decoration:underline; }

.shop-item h4:hover{ cursor:pointer; text-decoration:underline; }

.hidden{ display:none; }